<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/bg_cyan_rounded"
    android:padding="16dp">

    <ImageView
        android:id="@+id/tvEventImage"
        android:layout_width="141dp"
        android:layout_height="125dp"
        android:background="@drawable/bg_event_image_placeholder"
        android:clipToOutline="true"
        android:scaleType="fitXY"
        android:src="@drawable/img_placeholder"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvTicketTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textColor="#082238"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toStartOf="@id/tvEventImage"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginEnd="12dp"/>


    <TextView
        android:id="@+id/tvTicketDateTime"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:layout_marginEnd="12dp"
        android:textColor="#082238"
        app:layout_constraintEnd_toStartOf="@id/tvEventImage"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvTicketTitle" />


    <TextView
        android:id="@+id/tvTicketLocation"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:layout_marginEnd="12dp"
        android:textColor="#082238"
        app:layout_constraintEnd_toStartOf="@id/tvEventImage"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvTicketDateTime" />


    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnCancelTicket"
        android:layout_width="95dp"
        android:layout_height="48dp"
        android:layout_marginTop="12dp"
        android:text="@string/cancelTicketButton"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:textSize="13sp"
        app:backgroundTint="#C62828"
        app:cornerRadius="50dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvTicketLocation"
        app:strokeColor="#8B0000"
        app:strokeWidth="1dp" />

</androidx.constraintlayout.widget.ConstraintLayout>
