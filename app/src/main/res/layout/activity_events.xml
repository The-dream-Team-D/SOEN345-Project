<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/eventsMain"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".UIpages.EventsPageActivity"
    tools:theme="@style/Base.Theme.PopIn">

    <ImageView
        android:id="@+id/wave_image"
        android:layout_width="582dp"
        android:layout_height="203dp"
        android:contentDescription="@string/waveDesignDescription"
        android:scaleType="centerCrop"
        android:scaleX="1"
        android:scaleY="-1"

        android:src="@drawable/wave"

        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.672"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/EventsTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/EventsTitle"
        android:textColor="?attr/colorSecondary"
        android:textSize="42sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.497"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.178" />

    <EditText
        android:id="@+id/etSearchEvents"
        android:layout_width="386dp"
        android:layout_height="67dp"
        android:layout_marginHorizontal="10dp"
        android:layout_marginTop="20dp"
        android:background="@drawable/bg_search_bar"
        android:drawableStart="@android:drawable/ic_menu_search"
        android:drawablePadding="10dp"
        android:hint="@string/EventsPageSearchBarHint"
        android:inputType="text"
        android:padding="14dp"
        android:paddingEnd="50dp"
        android:textColor="#082238"
        android:textColorHint="#5F6C7B"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/EventsTitle" />

    <LinearLayout
        android:id="@+id/clearFilters"
        android:layout_width="45dp"
        android:layout_height="45dp"
        android:layout_marginEnd="14dp"
        android:background="@drawable/category_filter_outline"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:clipToOutline="true"

        android:orientation="vertical"
        android:padding="8dp"
        app:layout_constraintBottom_toBottomOf="@id/etSearchEvents"
        app:layout_constraintEnd_toEndOf="@id/etSearchEvents"
        app:layout_constraintTop_toTopOf="@id/etSearchEvents">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/ic_clear"
            android:scaleType="fitCenter"
            app:tint="@color/black" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/social_category"
        android:layout_width="55dp"
        android:layout_height="55dp"
        android:layout_marginStart="5dp"
        android:layout_marginTop="5dp"
        android:background="@drawable/category_filter_outline"
        android:clickable="true"
        android:focusable="true"
        android:clipToOutline="true"

        android:gravity="center"
        android:orientation="vertical"
        android:padding="8dp"
        app:layout_constraintEnd_toStartOf="@id/educational_category"
        app:layout_constraintHorizontal_chainStyle="packed"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/etSearchEvents">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitCenter"
            android:src="@drawable/social_icon"
            app:tint="@color/black" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/educational_category"
        android:layout_width="55dp"
        android:layout_height="55dp"
        android:layout_marginStart="10dp"
        android:layout_marginTop="5dp"
        android:background="@drawable/category_filter_outline"
        android:clickable="true"
        android:focusable="true"
        android:clipToOutline="true"

        android:gravity="center"
        android:orientation="vertical"
        android:padding="8dp"
        app:layout_constraintEnd_toStartOf="@id/professional_category"
        app:layout_constraintStart_toEndOf="@id/social_category"
        app:layout_constraintTop_toBottomOf="@id/etSearchEvents">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitCenter"
            android:src="@drawable/educational_icon"
            app:tint="@color/black" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/professional_category"
        android:layout_width="55dp"
        android:layout_height="55dp"
        android:layout_marginStart="10dp"
        android:layout_marginTop="5dp"
        android:background="@drawable/category_filter_outline"
        android:clickable="true"
        android:clipToOutline="true"

        android:focusable="true"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="8dp"
        app:layout_constraintEnd_toStartOf="@id/sports_category"
        app:layout_constraintStart_toEndOf="@id/educational_category"
        app:layout_constraintTop_toBottomOf="@id/etSearchEvents">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/professional_icon"
            android:scaleType="fitCenter"
            app:tint="@color/black" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/sports_category"
        android:layout_width="55dp"
        android:layout_height="55dp"
        android:layout_marginStart="10dp"
        android:layout_marginTop="5dp"
        android:background="@drawable/category_filter_outline"
        android:clickable="true"
        android:clipToOutline="true"

        android:focusable="true"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="8dp"
        app:layout_constraintEnd_toStartOf="@id/entertainment_category"
        app:layout_constraintStart_toEndOf="@id/professional_category"
        app:layout_constraintTop_toBottomOf="@id/etSearchEvents">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/sports_icon"
            android:scaleType="fitCenter"
            app:tint="@color/black" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/entertainment_category"
        android:layout_width="55dp"
        android:layout_height="55dp"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="10dp"
        android:layout_marginTop="5dp"
        android:background="@drawable/category_filter_outline"
        android:clickable="true"
        android:clipToOutline="true"

        android:focusable="true"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/sports_category"
        app:layout_constraintTop_toBottomOf="@id/etSearchEvents">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/entertainment_icon"
            android:scaleType="fitCenter"
            app:tint="@color/black" />

    </LinearLayout>

    <Button
        android:id="@+id/next_month_filter"
        style="@style/Widget.AppCompat.Button.Borderless"
        android:layout_width="152dp"
        android:layout_height="37dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/rounded_button_outline"
        android:clickable="true"
        android:clipToOutline="true"

        android:focusable="true"
        android:paddingHorizontal="16dp"
        android:paddingVertical="8dp"
        android:text="@string/EventTimeFilter"
        android:textAllCaps="false"
        android:textColor="@color/black"
        android:textSize="10sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/social_category" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvEvents"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginHorizontal="10dp"
        android:layout_marginTop="20dp"
        android:clipToPadding="false"
        android:paddingBottom="16dp"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintVertical_bias="0.007"

        app:layout_constraintBottom_toTopOf="@+id/bottomNav"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/next_month_filter"
        />

    <TextView
        android:id="@+id/tvEventsEmptyState"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="72dp"
        android:text="@string/eventsEmptyState"
        android:textColor="#082238"
        android:textSize="18sp"
        android:textStyle="bold"
        android:visibility="visible"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.478"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/rvEvents" />

    <com.example.popin.reusableUI.NavBarComponentView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:id="@+id/bottomNav"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>


</androidx.constraintlayout.widget.ConstraintLayout>

