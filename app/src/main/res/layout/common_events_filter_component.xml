<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/commonEventsFilter"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="20dp"
        android:layout_marginHorizontal="10dp"
        android:gravity="center_vertical">

        <EditText
            android:id="@+id/etSearchEvents"
            android:layout_width="0dp"
            android:layout_height="67dp"
            android:layout_weight="1"
            android:background="@drawable/bg_search_bar"
            android:drawableStart="@android:drawable/ic_menu_search"
            android:drawablePadding="10dp"
            android:hint="@string/EventsPageSearchBarHint"
            android:inputType="text"
            android:padding="14dp"
            android:paddingEnd="50dp"
            android:textColor="#082238"
            android:textColorHint="#5F6C7B" />

        <LinearLayout
            android:id="@+id/clearFilters"
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/category_filter_outline"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:padding="8dp">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/ic_clear"
                android:scaleType="fitCenter"
                app:tint="@color/black" />
        </LinearLayout>

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="10dp"
        android:gravity="center">

        <LinearLayout
            android:id="@+id/social_category"
            android:layout_width="55dp"
            android:layout_height="55dp"
            android:layout_marginHorizontal="5dp"
            android:background="@drawable/category_filter_outline"
            android:gravity="center"
            android:clickable="true"
            android:padding="8dp">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/social_icon"
                android:scaleType="fitCenter"
                app:tint="@color/black" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/educational_category"
            android:layout_width="55dp"
            android:layout_height="55dp"
            android:layout_marginHorizontal="5dp"
            android:background="@drawable/category_filter_outline"
            android:gravity="center"
            android:padding="8dp">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/educational_icon"
                android:scaleType="fitCenter"
                app:tint="@color/black" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/professional_category"
            android:layout_width="55dp"
            android:layout_height="55dp"
            android:layout_marginHorizontal="5dp"
            android:background="@drawable/category_filter_outline"
            android:gravity="center"
            android:padding="8dp">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/professional_icon"
                android:scaleType="fitCenter"
                app:tint="@color/black" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/sports_category"
            android:layout_width="55dp"
            android:layout_height="55dp"
            android:layout_marginHorizontal="5dp"
            android:background="@drawable/category_filter_outline"
            android:gravity="center"
            android:padding="8dp">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/sports_icon"
                android:scaleType="fitCenter"
                app:tint="@color/black" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/entertainment_category"
            android:layout_width="55dp"
            android:layout_height="55dp"
            android:layout_marginHorizontal="5dp"

            android:background="@drawable/category_filter_outline"
            android:gravity="center"
            android:padding="8dp">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/entertainment_icon"
                android:scaleType="fitCenter"
                app:tint="@color/black" />

        </LinearLayout>


    </LinearLayout>

    <Button
        android:id="@+id/next_month_filter"
        android:layout_width="wrap_content"
        android:layout_height="37dp"
        android:layout_marginTop="12dp"
        android:layout_gravity="center"
        android:background="@drawable/rounded_button_outline"
        android:text="@string/EventTimeFilter"
        android:textAllCaps="false"
        android:textColor="@color/black"
        android:textSize="10sp" />

</LinearLayout>